---
---

<div class="w-full max-w-lg mx-auto">
  <h2 class="text-2xl font-bold mb-4 text-center">Quelques informations</h2>

  <label class="block mb-3">Nom complet
    <input name="name" class="input input-bordered w-full mt-1" required />
  </label>

  <label class="block mb-3">E-mail
    <input name="email" type="email" class="input input-bordered w-full mt-1" required />
  </label>

  <label class="block mb-3">Téléphone
    <input name="phone" class="input input-bordered w-full mt-1" />
  </label>

  <label class="block mb-3">Age (facultatif)
    <input name="age" type="number" min="0" class="input input-bordered w-full mt-1" />
  </label>
</div>
