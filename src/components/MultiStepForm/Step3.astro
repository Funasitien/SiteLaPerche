<div class="w-full max-w-xl mx-auto">
  <h2 class="text-2xl font-bold mb-4 text-center">Quelles compétences possèdes-tu ?</h2>

  <p class="text-center text-sm mb-4">Sélectionne toutes les compétences qui te correspondent.</p>

  <div class="flex flex-wrap gap-3 justify-center mb-4">
    <label class="btn btn-outline">
      <input type="checkbox" name="skills" value="montage" class="hidden" /> Montage
    </label>
    <label class="btn btn-outline">
      <input type="checkbox" name="skills" value="acteur" class="hidden" /> Jeu d'acteur
    </label>
    <label class="btn btn-outline">
      <input type="checkbox" name="skills" value="cam" class="hidden" /> Caméra
    </label>
    <label class="btn btn-outline">
      <input type="checkbox" name="skills" value="son" class="hidden" /> Son
    </label>
    <label class="btn btn-outline">
      <input type="checkbox" name="skills" value="écriture" class="hidden" /> Écriture
    </label>
    <label class="btn btn-outline">
      <input type="checkbox" name="skills" value="production" class="hidden" /> Production
    </label>
  </div>

  <div class="text-center text-sm text-muted">Tu peux ajouter d'autres compétences dans le message final.</div>
</div>
