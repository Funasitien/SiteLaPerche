<div class="w-full max-w-lg mx-auto">
  <h2 class="text-2xl font-bold mb-4 text-center">Ajoute ton CV / portfolio</h2>

  <label class="block mb-4">Fichier (pdf, zip, mp4...)
    <input type="file" name="portfolio" class="file-input file-input-bordered w-full mt-1" />
  </label>

  <label class="block">Message / détails (facultatif)
    <textarea name="message" class="textarea textarea-bordered w-full mt-1" rows="4"></textarea>
  </label>
</div>
