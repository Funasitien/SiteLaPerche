---
import { Icon } from "astro-icon/components";
---

<div class="hero bg-secondary text-secondary-content mt-2 md:mt-4 p-4 rounded-box">
    <div class="max-w-3xl mx-auto text-center">
        <p class="mb-4">J'ai paniqué :</p>

            <div class="flex flex-col md:flex-row items-center justify-center gap-4">
                    <a href="https://instagram.com" target="_blank" rel="noopener noreferrer" class="p-4 bg-base-100 rounded-lg flex flex-col items-center justify-center gap-2 hover:shadow-lg transition transform hover:-translate-y-1 w-32" aria-label="Instagram">
                        <div class="text-3xl text-pink-500"><Icon name="mingcute:instagram-fill" /></div>
                        <span class="text-sm font-semibold">Instagram</span>
                    </a>

                    <a href="https://youtube.com" target="_blank" rel="noopener noreferrer" class="p-4 bg-base-100 rounded-lg flex flex-col items-center justify-center gap-2 hover:shadow-lg transition transform hover:-translate-y-1 w-32" aria-label="YouTube">
                        <div class="text-3xl text-red-500"><Icon name="mingcute:youtube-fill" /></div>
                        <span class="text-sm font-semibold">YouTube</span>
                    </a>

                    <a href="mailto:contact@example.com" class="p-4 bg-base-100 rounded-lg flex flex-col items-center justify-center gap-2 hover:shadow-lg transition transform hover:-translate-y-1 w-32" aria-label="Email">
                        <div class="text-3xl text-neutral"><Icon name="mingcute:mail-fill" /></div>
                        <span class="text-sm font-semibold">Email</span>
                    </a>
            </div>
    </div>
</div>