---
import { Image } from "astro:assets";
import Navigation from "./Navigation.astro";
import logo from "../assets/laperche.png";
---

<header class="space-y-4">
    <div class="navbar p-0 bg-secondary text-secondary-content rounded-box z-10">
        <div class="navbar-start">
            <div class="flex-none lg:hidden ml-4">
        <label for="my-drawer-2" aria-label="open sidebar" class="btn btn-square btn-secondary">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            fill="none"
            viewBox="0 0 24 24"
            class="inline-block h-6 w-6 stroke-current"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M4 6h16M4 12h16M4 18h16"
            ></path>
          </svg>
        </label>
      </div>
            <Image class="hidden md:block ml-8 h-16 w-auto" src={logo} alt="La Perche Logo"/>
        </div>
        <div class="navbar-center">
            <Image class="md:hidden ml-8 h-16 w-auto" src={logo} alt="La Perche Logo"/>
            <ul class="menu menu-horizontal px-1 hidden md:flex">
                <Navigation />
            </ul>
        </div>
        <div class="navbar-end gap-2">
           
        </div>
    </div>
</header>
