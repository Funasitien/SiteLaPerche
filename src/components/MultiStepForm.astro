---
import Step1 from "./MultiStepForm/Step1.astro";
import Step2 from "./MultiStepForm/Step2.astro";
import Step3 from "./MultiStepForm/Step3.astro";
import Step4 from "./MultiStepForm/Step4.astro";
---
<section class="h-full items-center justify-center px-4">
    <form id="multiForm" class="space-y-6">
      <div class="step" data-step="1">
        <Step1 />
      </div>

      <div class="step hidden" data-step="2">
        <Step2 />
      </div>

      <div class="step hidden" data-step="3">
        <Step3 />
      </div>

      <div class="step hidden" data-step="4">
        <Step4 />
      </div>

      <div class="flex items-center justify-between">
        <button type="button" id="prevBtn" class="btn">Précédent</button>
        <div class="flex gap-2">
          <button type="button" id="nextBtn" class="btn btn-primary">Suivant</button>
          <button type="submit" id="submitBtn" class="btn btn-secondary hidden">Envoyer</button>
        </div>
      </div>
    </form>

  <script>
    (function(){
      const form = document.getElementById('multiForm');
      const steps = Array.from(form.querySelectorAll('.step'));
      let idx = 0;
      const prevBtn = document.getElementById('prevBtn');
      const nextBtn = document.getElementById('nextBtn');
      const submitBtn = document.getElementById('submitBtn');

      const show = i => {
        steps.forEach((s, j) => s.classList.toggle('hidden', j !== i));
        nextBtn.style.display = (i === steps.length - 1 || i === 0) ? 'none' : 'inline-flex';
        submitBtn.classList.toggle('hidden', i !== steps.length -1);
        prevBtn.style.display = i === 0 ? 'none' : 'inline-flex';
        window.scrollTo({top:0,behavior:'smooth'});
      };

      show(idx);

      nextBtn.addEventListener('click', ()=>{ idx = Math.min(steps.length-1, idx+1); show(idx); });
      prevBtn.addEventListener('click', ()=>{ idx = Math.max(0, idx-1); show(idx); });

      form.addEventListener('submit', async e=>{
        e.preventDefault();
        const fd = new FormData(form);
        // Ensure skills checkboxes collect multiple values
        const skills = Array.from(form.querySelectorAll('input[type="checkbox"][name="skills"]:checked')).map(i=>i.value);
        fd.delete('skills');
        skills.forEach(s=>fd.append('skills[]', s));

        // For demo: log entries and file info
        const out = {};
        for (const pair of fd.entries()){
          out[pair[0]] = pair[1];
        }
        console.log('Form data', out);
        alert('Merci — formulaire reçu (démo). Voir console pour les données).');
      });
    })();
  </script>
</section>
